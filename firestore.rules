rules_version = '2';

// Firestore Security Rules for Misrak Shemeta Marketplace
//
// CRITICAL ARCHITECTURE NOTES:
// 1. This system uses TELEGRAM AUTHENTICATION (telegramId), NOT Firebase Auth
// 2. PRIMARY security enforcement is SERVER-SIDE via Next.js Server Actions with Firebase Admin SDK (Requirement 10)
// 3. These rules provide DEFENSE-IN-DEPTH as a backup layer
// 4. Multi-tenancy is enforced at data model level with shopId associations (Requirement 1)
// 5. All mutations MUST go through Server Actions - direct client writes are BLOCKED
//
// Since Firebase Security Rules cannot access Telegram context (request.auth will be null),
// we use a restrictive approach: DENY all writes, allow selective reads.
// Server Actions use Firebase Admin SDK which bypasses these rules.

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // USERS COLLECTION
    // ============================================================================
    // Requirement 2: Users associated with Location (Haramaya_Main, Harar_Campus, DDU)
    // Requirement 19: Telegram authentication with telegramId as primary identifier
    match /users/{userId} {
      // Public read for user profiles (needed for displaying user info in orders, etc.)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // SHOPS COLLECTION
    // ============================================================================
    // Requirement 1: Multi-tenant shop management with isolated data
    // Requirement 3: Shop registration with Location (Harar or Dire_Dawa)
    match /shops/{shopId} {
      // Public read for shop information (Requirement 5)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      // Server Actions enforce shop ownership via Firebase Admin SDK
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // PRODUCTS COLLECTION
    // ============================================================================
    // Requirement 1: Every Product associated with exactly one Shop via shopId
    // Requirement 4: Product CRUD with multi-tenant isolation
    match /products/{productId} {
      // Public read for product browsing (Requirement 5)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      // Server Actions verify product.shopId matches shop owner's shopId (Requirement 1)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // ORDERS COLLECTION
    // ============================================================================
    // Requirement 7: Order creation with userId, cart items, shopId associations
    // Requirement 8: Escrow payment lifecycle (PENDING → PAID_ESCROW → DISPATCHED → ARRIVED → COMPLETED)
    // Requirement 23: Firestore Transactions for all critical state changes
    match /orders/{orderId} {
      // Public read for orders (Server Actions filter by userId/shopId)
      // Needed for: users viewing their orders, shop owners viewing their orders, runners viewing assigned orders
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      // Server Actions use Firestore Transactions for state changes (Requirement 23)
      // Payment webhook implements idempotency checks (Requirement 24)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // CARTS COLLECTION
    // ============================================================================
    // Requirement 6: Shopping cart management with productId, quantity, userId
    match /carts/{cartId} {
      // Public read (Server Actions filter by userId)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // SHOP TRANSACTIONS COLLECTION
    // ============================================================================
    // Requirement 22: Shop owner balance management
    // Requirement 17: Funds released from escrow when order COMPLETED
    match /shopTransactions/{transactionId} {
      // Public read (Server Actions filter by shopId)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      // Transactions use Firestore Transactions for atomicity (Requirement 23)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // NOTIFICATIONS COLLECTION
    // ============================================================================
    // Order status change notifications (Requirement 9)
    match /notifications/{notificationId} {
      // Public read (Server Actions filter by userId)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // ADMIN LOGS COLLECTION
    // ============================================================================
    // Requirement 27-33: Admin dashboard, user/shop/order management, audit logging
    match /adminLogs/{logId} {
      // Admin-only read (enforced by Server Actions checking ADMIN_TELEGRAM_IDS)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // ERROR LOGS COLLECTION
    // ============================================================================
    // Requirement 33: System monitoring and error tracking
    match /errorLogs/{errorId} {
      // Admin-only read (enforced by Server Actions)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // WEBHOOK HISTORY COLLECTION
    // ============================================================================
    // Requirement 24: Payment webhook idempotency tracking
    match /webhookHistory/{webhookId} {
      // Admin-only read (enforced by Server Actions)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // PAYMENT RECORDS COLLECTION
    // ============================================================================
    // Requirement 8: Chapa payment integration and escrow tracking
    match /payments/{paymentId} {
      // Public read (Server Actions filter by userId/orderId)
      allow read: if true;
      
      // All writes handled by Server Actions (Requirement 10)
      allow create, update, delete: if false;
    }
    
    // ============================================================================
    // DEFAULT DENY
    // ============================================================================
    // Deny all access to any other collections not explicitly defined above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
