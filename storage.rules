rules_version = '2';

// Firebase Storage Security Rules for Misrak Shemeta Marketplace
// 
// IMPORTANT: This system uses Telegram authentication (telegramId), NOT Firebase Auth.
// Primary security enforcement is SERVER-SIDE via Next.js Server Actions with Firebase Admin SDK.
// These rules provide DEFENSE-IN-DEPTH as a backup layer.
//
// Since Firebase Storage rules cannot access Telegram context, we use a permissive approach
// with server-side validation being the primary security mechanism (Requirement 10).

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isValidImageSize() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB max (Requirement 13)
    }
    
    function isValidImageType() {
      // Support JPEG, PNG, WebP (Requirement 13)
      return request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    
    // Product images: /products/{shopId}/{productId}/image_{index}.{ext}
    // Multi-tenant isolation: Each product belongs to exactly one shop (Requirement 1)
    match /products/{shopId}/{allPaths=**} {
      // Public read for all product images (Requirement 5, 13)
      allow read: if true;
      
      // Write operations are validated server-side via Server Actions (Requirement 10)
      // Storage rules provide basic validation only
      allow write: if isValidImageSize() && isValidImageType();
      
      // Delete operations are validated server-side (Requirement 4, 10)
      allow delete: if true; // Server Actions enforce ownership
    }
    
    // Shop images: /shops/{shopId}/{imageId}
    match /shops/{shopId}/{allPaths=**} {
      // Public read for all shop images (Requirement 3)
      allow read: if true;
      
      // Write/delete validated server-side (Requirement 10)
      allow write: if isValidImageSize() && isValidImageType();
      allow delete: if true; // Server Actions enforce ownership
    }
    
    // User profile images: /users/{userId}/{imageId}
    match /users/{userId}/{allPaths=**} {
      // Public read for profile images
      allow read: if true;
      
      // Write/delete validated server-side (Requirement 10)
      allow write: if isValidImageSize() && isValidImageType();
      allow delete: if true; // Server Actions enforce ownership
    }
  }
}
